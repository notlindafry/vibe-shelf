# vibe-shelf environment variables
#
# Copy this file to .env.local and fill in the values:
#     cp .env.example .env.local
# .env.local holds your real secrets and is gitignored. Never commit it.
# This .env.example file contains no real values and is safe to commit.
#
# For the live site, set the same variables in your Vercel project:
#     Vercel > vibe-shelf > Settings > Environment Variables (Production scope).
# Real secret values belong in .env.local (local) and Vercel (production) only,
# never anywhere in git. The variable NAMES here must match exactly what you set
# in Vercel and what the app code reads.

# ---- Required: your Discogs account ----

# Discogs personal access token. Reads your collection. Server-side only.
# From your Discogs account developer settings (verify the exact path; I believe
# it is https://www.discogs.com/settings/developers - generate a personal token).
DISCOGS_TOKEN=

# Your Discogs username. Determines whose collection is read.
DISCOGS_USERNAME=

# A descriptive User-Agent string the Discogs API requires on requests. Applies to
# ALL Discogs calls (both accounts). You choose it; include an app name and a
# contact or URL, for example: vibe-shelf/1.0 (+https://vibe-shelf.vercel.app)
DISCOGS_USER_AGENT=

# ---- Optional: second Discogs account (shared household shelf) ----
# Leave both blank to run a single-account catalogue. When both are set, the app
# fetches this account's collection too, stamps each record with its owner, and
# merges the two into one shelf with an owner filter.
# Use this account's OWN token. Whether Discogs lets one account's token read
# another account's collection is not something I can confirm, so the reliable
# design is one token per account (works whether the collection is public or private).

# Second account's Discogs username.
DISCOGS_USERNAME_2=

# Second account's own Discogs personal access token (their secret).
DISCOGS_TOKEN_2=

# ---- Optional: owner labels ----
# Friendly names for the owner filter. If blank, the filter falls back to the raw
# Discogs usernames above.
DISCOGS_LABEL=
DISCOGS_LABEL_2=

# ---- Required: search ----

# Anthropic API key. Required for natural-language / vibe search; without it the
# app falls back to basic keyword search (lib/search.ts reads this exact name).
# From https://console.anthropic.com/ > API Keys > Create key.
ANTHROPIC_API_KEY=

# ---- Optional: Last.fm (cross-artist similarity + listener-tag mood grounding) ----
# Enables two collection-first signals Discogs can't give: cross-artist sonic
# similarity ("more like this" that connects records that sound alike even when
# their style tags diverge) and crowd-sourced listener tags that ground the mood
# classifier. Both are precomputed server-side by the hydrate-lastfm cron into
# Redis, so the read path stays free, and the key never reaches the browser.
# Leave blank to run without it: similarity falls back to style-based matching and
# moods to the Claude-plus-heuristic path — everything still works.
# Get a key from https://www.last.fm/api/account/create (verify the current path).
LASTFM_API_KEY=

# ---- Required: security (access to the app) ----

# The password you type to unlock the app (the "owner": full access).
APP_PASSWORD=

# A long random string (>= 16 chars) used to sign login sessions.
# You GENERATE this yourself; it is not fetched from any service. For example:
#   openssl rand -base64 32
# Use a FRESH value; do not reuse another app's session secret.
# If APP_PASSWORD or SESSION_SECRET is missing, the app fails closed (no access).
SESSION_SECRET=

# ---- Optional ----

# A second password for read-only sharing (guests can browse but not change
# anything). Independent of whose collections are shown. Leave blank to disable.
APP_GUEST_PASSWORD=

# Which Claude model to use for query understanding and ranking. Defaults to
# claude-haiku-4-5 (fast, low cost). Verify the current model name in the Anthropic
# docs before overriding, since model names change over time.
ANTHROPIC_MODEL=claude-haiku-4-5

# How long (seconds) to cache each Discogs collection in memory before re-fetching.
# Lower means new records appear faster; higher means fewer Discogs calls.
DISCOGS_CACHE_TTL_SECONDS=300

# ---- Optional: insights carousel (feature 6) ----
# The home-view carousel shows model-generated insights about the merged
# collection. Generation runs on the daily cron and only when the shelf actually
# changed, so the read path is free (the carousel rotates a cached batch). Without
# an Anthropic key or Redis it falls back to code-computed stat cards.
#
# How stale (ms) a cached batch may get before the cron regenerates it even when
# the collection is unchanged (a freshness/variety ceiling). Default 22 hours, so
# the daily cron refreshes the carousel with new insights every day; it is kept
# just under 24h so cron timing drift can't leave the batch one run short of the
# threshold and skip a day. Set very high (e.g. 31536000000 for a year) to mean
# "only regenerate on change", which is near-zero cost.
INSIGHTS_MAX_AGE_MS=79200000
# Per-day cap on insight generations — a cost safety-belt against a bug or retry
# storm. Keep CAP * ~$0.011/generation * 30 under your monthly ceiling; ~8 keeps
# the worst case under $3. The change/staleness gate keeps the real rate far below.
INSIGHTS_DAILY_CAP=8

# ---- Optional: maybe-vibes wishlist (Spotify album search) ----
# The maybe-vibes tab finds albums through Spotify search and shortlists them.
# Spotify is reached with the Client Credentials flow (an app-level token, public
# catalog only, no user login). Both values are SERVER-SIDE ONLY: they are read
# from process.env in lib/spotify.ts, never sent to the browser, and never logged.
# Do NOT prefix either with NEXT_PUBLIC_ (that would bundle them into the client).
# Create an app at https://developer.spotify.com/dashboard (select "Web API") to
# get these. Without them, the maybe-vibes tab still loads but search is disabled.
# The wishlist itself also requires Upstash Redis (below) to persist.
SPOTIFY_CLIENT_ID=
# Secret. Keep it out of git and out of the client bundle; set it in Vercel only.
SPOTIFY_CLIENT_SECRET=

# ---- Upstash Redis (global rate limiting, collection cache, QuerySpec cache) ----
# Redis backs global rate limiting, the persistent collection cache, and the
# QuerySpec cache. Create a free database at https://upstash.com/ and set both.
# The token is a full credential for the database — keep it secret, server-side only.
# fromEnv() also accepts the KV_REST_API_URL / KV_REST_API_TOKEN names if you linked
# the database through Vercel's integration. When unset, the app fails open: it uses
# the in-memory rate limiter and live Discogs fetches, so it still works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Cron: background refresh jobs ----
# Shared secret guarding /api/cron/* internal routes (collection refresh, track
# hydration, and insights generation). Set this in Vercel and the
# platform automatically sends it as `Authorization: Bearer <CRON_SECRET>` on every
# scheduled run; requests without it are rejected. Generate a long random value, e.g.
#   openssl rand -base64 32
# The cron schedule itself lives in vercel.json. Sub-daily schedules require a Vercel
# Pro plan; on Hobby the cache still stays fresh via stale-while-revalidate on reads.
CRON_SECRET=
